{
  "sea_level": 0,
  "disable_mob_generation": true,
  "aquifers_enabled": false,
  "ore_veins_enabled": false,
  "legacy_random_source": false,

  "default_block": {
    "Name": "minecraft:basalt"
  },

  "default_fluid": {
    "Name": "minecraft:air"
  },

  "spawn_target": [
    {
      "temperature": 0,
      "humidity": 0,
      "continentalness": 0,
      "erosion": 0,
      "depth": 0,
      "weirdness": 0,
      "offset": 0
    }
  ],

  "noise": {
    "min_y": -64,
    "height": 384,
    "size_horizontal": 1,
    "size_vertical": 2
  },

  "noise_router": {
    "barrier": {
      "type": "minecraft:constant",
      "argument": 0
    },

    "fluid_level_floodedness": {
      "type": "minecraft:constant",
      "argument": 0
    },

    "fluid_level_spread": {
      "type": "minecraft:constant",
      "argument": 0
    },

    "lava": {
      "type": "minecraft:constant",
      "argument": 0
    },

    "temperature": {
      "type": "minecraft:constant",
      "argument": 0
    },

    "vegetation": {
      "type": "minecraft:constant",
      "argument": 0
    },

    "continents": {
      "type": "minecraft:noise",
      "noise": "minecraft:continentalness",
      "xz_scale": 0.25,
      "y_scale": 0
    },

    "erosion": {
      "type": "minecraft:noise",
      "noise": "minecraft:erosion",
      "xz_scale": 0.25,
      "y_scale": 0
    },

    "depth": {
      "type": "minecraft:constant",
      "argument": 0
    },

    "ridges": {
      "type": "minecraft:constant",
      "argument": 0
    },

    "initial_density_without_jaggedness": {
      "type": "minecraft:constant",
      "argument": 0
    },

    "final_density": {
      "type": "minecraft:add",
      "argument1": {
        "type": "minecraft:add",
        "argument1": "terraforming_mars:dunes",
        "argument2": {
          "type": "minecraft:y_clamped_gradient",
          "from_y": -64,
          "to_y": 100,
          "from_value": 60,
          "to_value": -60
        }
      },
      "argument2": "terraforming_mars:crater"
    },

    "vein_toggle": {
      "type": "minecraft:constant",
      "argument": 0
    },

    "vein_ridged": {
      "type": "minecraft:constant",
      "argument": 0
    },

    "vein_gap": {
      "type": "minecraft:constant",
      "argument": 0
    }
  },

  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:biome",
          "biome_is": ["terraforming_mars:dune_field"]
        },
        "then_run": {
          "type": "minecraft:sequence",
          "sequence": [
            {
              "type": "minecraft:condition",
              "if_true": {
                "type": "minecraft:stone_depth",
                "offset": 0,
                "surface_type": "floor",
                "add_surface_depth": false,
                "secondary_depth_range": 0
              },
              "then_run": {
                "type": "minecraft:condition",
                "if_true": {
                  "type": "minecraft:vertical_gradient",
                  "random_name": "terraforming_mars:red_sand_patch",
                  "true_at_and_below": { "above_bottom": 0 },
                  "false_at_and_above": { "above_bottom": 4 }
                },
                "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:red_sand" } },
                "else_run": { "type": "minecraft:block", "result_state": { "Name": "terraforming_mars:dust_deposit" } }
              }
            },
            {
              "type": "minecraft:condition",
              "if_true": {
                "type": "minecraft:stone_depth",
                "offset": 1,
                "surface_type": "floor",
                "add_surface_depth": false,
                "secondary_depth_range": 0
              },
              "then_run": { "type": "minecraft:block", "result_state": { "Name": "terraforming_mars:dust_deposit" } }
            },
            {
              "type": "minecraft:condition",
              "if_true": {
                "type": "minecraft:stone_depth",
                "offset": 2,
                "surface_type": "floor",
                "add_surface_depth": false,
                "secondary_depth_range": 0
              },
              "then_run": { "type": "minecraft:block", "result_state": { "Name": "terraforming_mars:dust_deposit" } }
            }
          ]
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:biome",
          "biome_is": ["terraforming_mars:iron_highlands"]
        },
        "then_run": {
          "type": "minecraft:condition",
          "if_true": {
            "type": "minecraft:stone_depth",
            "offset": 6,
            "surface_type": "floor",
            "add_surface_depth": false,
            "secondary_depth_range": 3
          },
          "then_run": { "type": "minecraft:block", "result_state": { "Name": "terraforming_mars:hematite_layer" } }
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:biome",
          "biome_is": ["terraforming_mars:sulfate_flats"]
        },
        "then_run": {
          "type": "minecraft:condition",
          "if_true": {
            "type": "minecraft:stone_depth",
            "offset": 5,
            "surface_type": "floor",
            "add_surface_depth": false,
            "secondary_depth_range": 2
          },
          "then_run": { "type": "minecraft:block", "result_state": { "Name": "terraforming_mars:sulfate_rock" } }
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:biome",
          "biome_is": ["terraforming_mars:crater_field"]
        },
        "then_run": {
          "type": "minecraft:condition",
          "if_true": {
            "type": "minecraft:stone_depth",
            "offset": 10,
            "surface_type": "floor",
            "add_surface_depth": false,
            "secondary_depth_range": 4
          },
          "then_run": { "type": "minecraft:block", "result_state": { "Name": "terraforming_mars:ironstone" } }
        }
      }
    ]
  }
}